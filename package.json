{
  "name": "@hypercliq/shutdown-cleanup",
  "version": "8.0.2",
  "description": "Phased graceful shutdown for Node.js — signal handlers, async cleanup, configurable error strategy",
  "type": "module",
  "exports": {
    "types": "./index.d.ts",
    "default": "./index.js"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node --test tests/index.test.js",
    "test:coverage": "c8 --reporter=html --reporter=text-summary node --test tests/index.test.js",
    "lint": "eslint index.js tests/*.js",
    "lint:fix": "eslint --fix index.js tests/*.js",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hypercliq/shutdown-cleanup.git"
  },
  "keywords": [
    "graceful-shutdown",
    "graceful",
    "shutdown",
    "cleanup",
    "signal",
    "sigterm",
    "sigint",
    "sighup",
    "process",
    "exit",
    "handler",
    "hooks",
    "lifecycle",
    "phased-shutdown",
    "async",
    "typescript",
    "esm",
    "nodejs"
  ],
  "author": "Hypercliq",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hypercliq/shutdown-cleanup/issues"
  },
  "homepage": "https://hypercliq.github.io/shutdown-cleanup",
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "c8": "^12.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-unicorn": "^72.0.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5"
  }
}
